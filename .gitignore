# =====================================
# Next.js 项目 Git 忽略文件
# =====================================

# =====================================
# 依赖目录
# =====================================
node_modules/

# =====================================
# 构建产物
# =====================================
.next/
out/
build/
dist/

# =====================================
# 缓存
# =====================================
.cache/
.parcel-cache/
.fusebox/
.eslintcache
*.tsbuildinfo

# =====================================
# 环境变量
# =====================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# =====================================
# 测试覆盖率
# =====================================
coverage/
.nyc_output/

# =====================================
# 调试日志
# =====================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =====================================
# 操作系统
# =====================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# =====================================
# 编辑器
# =====================================
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# =====================================
# 临时文件
# =====================================
*.tmp
*.bak
*.backup

# =====================================
# IDE 配置文件（可选，根据需要添加）
# =====================================
*.iml
.project
.classpath
.settings/
copilot/
.cursor/

# =====================================
# 运行时间文件
# =====================================
pids
*.pid
*.seed
*.pid.lock