{
    "name": "zhijian-hub",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "check": "npm run lint && npm run typecheck && npm run test",
        "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\" \"*.{ts,json,md}\"",
        "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css}\" \"*.{ts,json,md}\""
    },
    "dependencies": {
        "clsx": "^2.1.1",
        "next": "15.5.20",
        "react": "19.1.0",
        "react-dom": "19.1.0"
    },
    "devDependencies": {
        "@testing-library/react": "^16.3.2",
        "@types/node": "22.15.30",
        "@types/react": "19.1.6",
        "@types/react-dom": "19.1.5",
        "eslint": "^8.57.1",
        "eslint-config-next": "^15.5.20",
        "jsdom": "^29.1.1",
        "prettier": "^3.9.4",
        "typescript": "5.8.3",
        "vitest": "^3.2.6"
    },
    "overrides": {
        "postcss": "8.5.19"
    }
}
