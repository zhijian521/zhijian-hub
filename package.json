{
    "name": "zhijian-hub",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "next lint",
        "typecheck": "tsc --noEmit",
        "check": "npm run lint && npm run typecheck",
        "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\" \"*.{json,md}\"",
        "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css}\" \"*.{json,md}\""
    },
    "dependencies": {
        "next": "15.3.8",
        "react": "19.1.0",
        "react-dom": "19.1.0",
        "clsx": "^2.1.1"
    },
    "devDependencies": {
        "@types/node": "22.15.30",
        "@types/react": "19.1.6",
        "@types/react-dom": "19.1.5",
        "eslint": "^8.57.1",
        "eslint-config-next": "^15.5.20",
        "prettier": "^3.9.4",
        "typescript": "5.8.3"
    }
}
